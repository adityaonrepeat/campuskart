generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Better Auth required models ─────────────────────────────────────────────

enum Role {
  USER
  MODERATOR
  ADMIN
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  emailVerified   Boolean   @default(false)
  name            String
  username        String    @unique
  displayUsername String?
  avatarUrl       String?
  bio             String?
  image           String?
  phone           String?
  collegeId       String?
  role            Role      @default(USER)
  lastSeen        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  college              College?                  @relation(fields: [collegeId], references: [id])
  sessions             Session[]
  accounts             Account[]
  listings             Listing[]
  sentMessages         Message[]                 @relation("SentMessages")
  conversations        ConversationParticipant[]
  moderationLogs       ModerationLog[]
  store                Store?                    @relation("StoreOwner")
  archivedStores       Store[]                   @relation("StoreArchivedBy")
  storeReviews         StoreReview[]             @relation("StoreReviewAuthor")
  archivedReviews      StoreReview[]             @relation("StoreReviewArchivedBy")

  @@index([collegeId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

// ─── App models ───────────────────────────────────────────────────────────────

model College {
  id    String @id @default(cuid())
  name  String @unique
  city  String
  state String

  users          User[]
  listings       Listing[]
  stores         Store[]
  moderationLogs ModerationLog[]

  @@index([name])
}

enum ListingCategory {
  BOOKS
  ELECTRONICS
  CLOTHING
  FURNITURE
  NOTES
  SPORTS
  OTHER
}

enum ItemCondition {
  NEW
  LIKE_NEW
  GOOD
  FAIR
  POOR
}

enum ListingStatus {
  ACTIVE
  SOLD
  ARCHIVED
}

enum ListingType {
  FIXED_PRICE
  NEGOTIABLE
}

model Listing {
  id          String          @id @default(cuid())
  title       String
  description String
  price       Float
  images      String[]
  category    ListingCategory
  condition   ItemCondition
  status      ListingStatus   @default(ACTIVE)
  listingType ListingType     @default(FIXED_PRICE)
  sellerId    String
  collegeId   String
  storeId     String?         // set when posted as a store listing — excluded from main feed
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  seller        User           @relation(fields: [sellerId], references: [id])
  college       College        @relation(fields: [collegeId], references: [id])
  store         Store?         @relation(fields: [storeId], references: [id], onDelete: SetNull)
  conversations Conversation[]

  @@index([collegeId, status, listingType])
  @@index([sellerId])
  @@index([category])
  @@index([storeId])
}

model Conversation {
  id            String    @id @default(cuid())
  listingId     String?
  storeId       String?
  collegeId     String
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())

  listing      Listing?                  @relation(fields: [listingId], references: [id], onDelete: SetNull)
  store        Store?                    @relation(fields: [storeId], references: [id], onDelete: SetNull)
  participants ConversationParticipant[]
  messages     Message[]

  @@index([collegeId, lastMessageAt(sort: Desc)])
}

model ConversationParticipant {
  id             String    @id @default(cuid())
  conversationId String
  userId         String
  lastReadAt     DateTime?
  hiddenAt       DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("SentMessages", fields: [senderId], references: [id])

  @@index([conversationId, createdAt])
}

model ModerationLog {
  id           String   @id @default(cuid())
  moderatorId  String
  listingId    String
  listingTitle String
  sellerName   String
  collegeId    String
  reason       String?
  createdAt    DateTime @default(now())

  moderator User    @relation(fields: [moderatorId], references: [id])
  college   College @relation(fields: [collegeId], references: [id])

  @@index([moderatorId])
  @@index([collegeId])
  @@index([createdAt(sort: Desc)])
}

// ─── Campus Stores ─────────────────────────────────────────────────────────────

enum StoreCategory {
  FOOD_DRINKS
  STATIONERY
  CLOTHING
  ELECTRONICS
  SERVICES
  HEALTH_BEAUTY
  BOOKS
  OTHER
}

enum StoreStatus {
  PENDING   // awaiting admin verification — not visible to students
  ACTIVE    // verified, publicly visible
  ARCHIVED  // hidden by admin
}

model Store {
  id           String        @id @default(cuid())
  name         String
  description  String
  phone        String?
  whatsapp     String?
  category     StoreCategory
  images       String[]      // storefront photos (first is cover)
  menuImages   String[]      // menu / product photos
  location     String?       // campus location text (e.g. "Block C, Ground Floor")
  mapUrl       String?       // Google Maps share URL added by owner
  hours        String?       // free-text hours (e.g. "Mon–Fri 9 am–7 pm")
  quickReplies String[]      // owner-defined quick-reply buttons in chat
  tags         String[]      // searchable food/item tags e.g. ["biryani", "chicken"]
  isVerified   Boolean       @default(false)
  status       StoreStatus   @default(PENDING)
  ownerId      String        @unique   // one store per user — enforced at DB level
  collegeId    String
  archivedAt   DateTime?
  archivedById String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  owner         User           @relation("StoreOwner", fields: [ownerId], references: [id])
  college       College        @relation(fields: [collegeId], references: [id])
  archivedBy    User?          @relation("StoreArchivedBy", fields: [archivedById], references: [id])
  listings      Listing[]
  reviews       StoreReview[]
  conversations Conversation[]

  @@index([collegeId, status])
  @@index([category])
  @@index([createdAt(sort: Desc)])
}

model StoreReview {
  id           String    @id @default(cuid())
  storeId      String
  userId       String
  rating       Int       // 1–5
  body         String?
  isArchived   Boolean   @default(false)
  archivedAt   DateTime?
  archivedById String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  store      Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user       User   @relation("StoreReviewAuthor", fields: [userId], references: [id])
  archivedBy User?  @relation("StoreReviewArchivedBy", fields: [archivedById], references: [id])

  @@unique([storeId, userId])   // one review per user per store
  @@index([storeId])
  @@index([userId])
}
